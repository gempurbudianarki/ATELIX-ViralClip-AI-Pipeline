# ─── ATELIX ViralClip AI Pipeline ───

# Database
DATABASE_URL=postgresql+asyncpg://ai_cliper:ai_cliper_secret@localhost:5432/ai_cliper
DATABASE_URL_SYNC=postgresql://ai_cliper:ai_cliper_secret@localhost:5432/ai_cliper

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# OpenAI (fallback jika MCP unavailable)
OPENAI_API_KEY=sk-your-key-here

# OpenCode MCP
OPENCODE_MCP_ENABLED=true
OPENCODE_BINARY_PATH=opencode

# Whisper (local model)
WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=cuda  # atau "cpu" kalau tanpa GPU
WHISPER_COMPUTE_TYPE=float16  # atau "int8" untuk CPU

# FFmpeg
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe

# Playwright (TikTok publishing)
TIKTOK_USERNAME=
TIKTOK_PASSWORD=
TIKTOK_HEADLESS=false  # set true untuk production
TIKTOK_PROXY=  # opsional: http://user:pass@host:port

# App
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-to-random-string
API_HOST=0.0.0.0
API_PORT=8000

# Paths
DATA_DIR=./data
TEMP_DIR=./data/temp
OUTPUT_DIR=./data/output
MODELS_DIR=./data/models

# Limits
MAX_VIDEO_DURATION_SECONDS=7200  # 2 jam
MAX_CLIP_DURATION_SECONDS=180    # 3 menit (TikTok max)
DEFAULT_CLIP_DURATION_SECONDS=60
